# Copy to .env and fill in. Any blank key -> that integration serves mock data.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true

# GitHub
GITHUB_TOKEN=
GITHUB_USER=

# Render
RENDER_API_KEY=
RENDER_COST_THRESHOLD=1.62

# Google Cloud
GCP_API_KEY=
GCP_PROJECT=

# SendGrid
SENDGRID_API_KEY=

# Notion
NOTION_TOKEN=
NOTION_TASKS_DB=

# Notifications
DISCORD_WEBHOOK_URL=

# AI assistant (local Ollama; falls back to rule-based if server down)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Encryption key for stored tokens (Fernet, base64 32 bytes)
TOKEN_ENCRYPTION_KEY=

# Scheduler poll interval seconds
SCHEDULER_INTERVAL=300

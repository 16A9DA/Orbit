# Copy to .env and fill in. Any blank integration key -> that integration serves mock data.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true

# GitHub
GITHUB_TOKEN=
GITHUB_USER=

# Render
RENDER_API_KEY=
RENDER_COST_THRESHOLD=1.62

# Google Cloud
GCP_API_KEY=
GCP_PROJECT=

# SendGrid
SENDGRID_API_KEY=

# Notifications — Discord (Orbit server)
# DISCORD_WEBHOOK_URL is the fallback used when a channel-specific one is blank.
DISCORD_WEBHOOK_URL=
# Per-channel webhooks: Server Settings -> Integrations -> Webhooks, one per channel.
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_SECURITY=
DISCORD_WEBHOOK_BILLING=
DISCORD_WEBHOOK_DEPLOYMENTS=
DISCORD_WEBHOOK_LOGS=
DISCORD_WEBHOOK_GENERAL=

# AI assistant (local Ollama; falls back to rule-based if server down)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Encryption key for stored tokens (Fernet, base64 32 bytes)
TOKEN_ENCRYPTION_KEY=

# Scheduler poll interval seconds
SCHEDULER_INTERVAL=300
